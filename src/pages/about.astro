---
import { getCollection } from "astro:content";
import AboutExperience from "../components/about-experience.astro";
import EducationItem from "../components/education-item.astro";
// import PageHeading from "../components/page-heading.astro";
import Layout from "../layouts/main.astro";

// Get experiences and sort by order
const experiences = (await getCollection("experiences")).sort(
  (a, b) => a.data.order - b.data.order,
);

// Get education and sort by order
const education = (await getCollection("education")).sort(
  (a, b) => a.data.order - b.data.order,
);
---

<Layout showConsultation={true} title="About Me" meta={[]}>
  <div class="relative overflow-hidden">
    <!-- Background Decoration -->
    <div class="absolute inset-0 -z-10">
      <div
        class="absolute top-20 right-0 w-96 h-96 bg-primary-500/10 rounded-full blur-3xl"
      >
      </div>
      <div
        class="absolute bottom-20 left-0 w-96 h-96 bg-accent-500/10 rounded-full blur-3xl"
      >
      </div>
    </div>

    <section
      class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-16 sm:py-20 lg:py-24"
    >
      <!-- Header -->
      <div class="text-center space-y-6 mb-16 animate-fade-in">
        <div
          class="inline-flex items-center px-4 py-2 rounded-full bg-primary-100 dark:bg-primary-900/30 border border-primary-200 dark:border-primary-800"
        >
          <span
            class="text-sm font-semibold text-primary-700 dark:text-primary-300"
            >Get to know me</span
          >
        </div>

        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold tracking-tight">
          <span class="block text-neutral-900 dark:text-white">About</span>
          <span
            class="block bg-gradient-to-r from-primary-600 to-accent-500 bg-clip-text text-transparent"
          >
            Muhabbat Ali
          </span>
        </h1>

        <p
          class="text-lg sm:text-xl text-neutral-600 dark:text-neutral-400 max-w-2xl mx-auto flex items-center justify-center gap-2 flex-wrap"
        >
          <span
            >Hello 👋 I'm a Software Engineer specializing in full stack
            development.</span
          >
          <img
            src="/assets/icons/france-flag.png"
            class="w-6 h-auto"
            alt="France flag"
          />
        </p>
        <p
          class="text-base text-neutral-600 dark:text-neutral-400 max-w-2xl mx-auto"
        >
          I'm passionate about building new products and learning new
          technology.
        </p>
      </div>

      <!-- Image -->
      <div class="relative mb-16 animate-scale-in">
        <div
          class="absolute -inset-4 bg-gradient-to-r from-primary-500 to-accent-500 rounded-3xl blur-2xl opacity-20"
        >
        </div>
        <img
          src="/assets/images/about.jpg"
          class="relative w-full rounded-3xl shadow-2xl border-4 border-white dark:border-neutral-800"
          alt="About Muhabbat Ali"
        />
      </div>

      <!-- Short Bio -->
      <div class="glass rounded-3xl p-8 sm:p-10 mb-12 animate-slide-up">
        <h2
          class="text-2xl sm:text-3xl font-bold text-neutral-900 dark:text-white mb-4 flex items-center gap-3"
        >
          <span
            class="w-1 h-8 bg-gradient-to-b from-primary-500 to-accent-500 rounded-full"
          ></span>
          Short Bio
        </h2>
        <p
          class="text-base sm:text-lg leading-relaxed text-neutral-700 dark:text-neutral-300"
        >
          Full Stack Developer 🧑🏻‍💻, Flutter Developer 🤷🏻‍♂️, DevOps Engineer 🤦🏻‍♂️.
        </p>
      </div>

      <!-- Experience -->
      <div class="mb-12">
        <h2
          class="text-2xl sm:text-3xl font-bold text-neutral-900 dark:text-white mb-8 flex items-center gap-3"
        >
          <span
            class="w-1 h-8 bg-gradient-to-b from-primary-500 to-accent-500 rounded-full"
          ></span>
          Experience
        </h2>
        <div class="space-y-6 md:space-y-8 md:pl-8">
          {
            experiences.map(async (experience, loop) => {
              const { Content } = await experience.render();
              return (
                <div class="md:border-l-2 border-neutral-200 dark:border-neutral-800 md:pl-8 md:pb-8">
                  <AboutExperience
                    startDate={experience.data.startDate}
                    endDate={experience.data.endDate}
                    current={experience.data.current}
                    role={experience.data.role}
                    company={experience.data.company}
                    logo={experience.data.logo}
                  >
                    <Content />
                  </AboutExperience>
                </div>
              );
            })
          }
        </div>
      </div>

      <!-- Education -->
      <div class="mb-12">
        <h2
          class="text-2xl sm:text-3xl font-bold text-neutral-900 dark:text-white mb-8 flex items-center gap-3"
        >
          <span
            class="w-1 h-8 bg-gradient-to-b from-primary-500 to-accent-500 rounded-full"
          ></span>
          Education
        </h2>
        <div class="space-y-6">
          {
            education.map(async (edu) => {
              const { Content } = await edu.render();
              return (
                <EducationItem
                  degree={edu.data.degree}
                  field={edu.data.field}
                  institution={edu.data.institution}
                  logo={edu.data.logo}
                  startDate={edu.data.startDate}
                  endDate={edu.data.endDate}
                  current={edu.data.current}
                  location={edu.data.location}
                >
                  <Content />
                </EducationItem>
              );
            })
          }
        </div>
      </div>

      <!-- Let's Connect -->
      <div class="glass rounded-3xl p-8 sm:p-10 animate-slide-up">
        <h2
          class="text-2xl sm:text-3xl font-bold text-neutral-900 dark:text-white mb-6 flex items-center gap-3"
        >
          <span
            class="w-1 h-8 bg-gradient-to-b from-primary-500 to-accent-500 rounded-full"
          ></span>
          Let's Connect
        </h2>
        <div
          class="space-y-4 text-base sm:text-lg leading-relaxed text-neutral-700 dark:text-neutral-300"
        >
          <p>
            If you want to stay up to date with my work be sure to follow me on{
              " "
            }
            <a
              href="https://x.com/MuhabbatDev"
              target="_blank"
              class="text-primary-600 dark:text-primary-400 hover:text-primary-700 dark:hover:text-primary-300 font-semibold underline-offset-4 hover:underline transition-colors"
            >
              X
            </a>
            , or{" "}
            <a
              href="https://linkedin.com/in/muhabbat-ali"
              target="_blank"
              class="text-primary-600 dark:text-primary-400 hover:text-primary-700 dark:hover:text-primary-300 font-semibold underline-offset-4 hover:underline transition-colors"
            >
              LinkedIn
            </a>
            .
          </p>
          <p>
            You can send me an email at{" "}
            <a
              href="mailto:hello@muhabbat.dev"
              class="text-primary-600 dark:text-primary-400 hover:text-primary-700 dark:hover:text-primary-300 font-semibold underline-offset-4 hover:underline transition-colors"
            >
              hello@muhabbat.dev
            </a>
            {" "}and I'll be sure to get back to you.
          </p>
          <p>
            If you are looking to work with me, you can see my services on{" "}
            <a
              href="https://muhabbat.contra.com/"
              target="_blank"
              class="text-primary-600 dark:text-primary-400 hover:text-primary-700 dark:hover:text-primary-300 font-semibold underline-offset-4 hover:underline transition-colors"
            >
              Contra
            </a>
            .
          </p>
        </div>
      </div>
    </section>
  </div>

  <!-- Horizontal -->
  <ins
    class="adsbygoogle"
    style="display:block"
    data-ad-client="ca-pub-7415679537348503"
    data-ad-slot="2980813441"
    data-ad-format="auto"
    data-full-width-responsive="true"></ins>
</Layout>
