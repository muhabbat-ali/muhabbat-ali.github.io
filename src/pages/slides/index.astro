---
import Layout from "@/layouts/main";
import { getCollection } from "astro:content";
import { cn } from "@/utils";

// Get all slides sorted by date
const slides = (await getCollection("slides")).sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime(),
);
---

<Layout title="Slides" showConsultation={false} meta={[]}>
  <div class="relative overflow-hidden">
    <!-- Background Decoration -->
    <div class="absolute inset-0 -z-10">
      <div
        class="absolute top-20 right-0 w-96 h-96 bg-primary-500/10 rounded-full blur-3xl"
      >
      </div>
      <div
        class="absolute bottom-20 left-0 w-96 h-96 bg-accent-500/10 rounded-full blur-3xl"
      >
      </div>
    </div>

    <section
      class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 sm:py-20 lg:py-24"
    >
      <!-- Header -->
      <div class="text-center space-y-6 mb-16 animate-fade-in">
        <div
          class="inline-flex items-center px-4 py-2 rounded-full bg-primary-100 dark:bg-primary-900/30 border border-primary-200 dark:border-primary-800"
        >
          <span
            class="text-sm font-semibold text-primary-700 dark:text-primary-300"
          >
            📊 Presentations
          </span>
        </div>

        <h1
          class="flex justify-center text-4xl sm:text-5xl lg:text-6xl font-bold tracking-tight"
        >
          <span class="block text-neutral-900 dark:text-white pr-1">My</span>
          <span
            class="block bg-gradient-to-r from-primary-600 to-accent-500 bg-clip-text text-transparent"
          >
            Slides
          </span>
        </h1>

        <p
          class="text-lg sm:text-xl text-neutral-600 dark:text-neutral-400 max-w-2xl mx-auto"
        >
          My presentations and slide decks
        </p>
      </div>

      <!-- Slides Grid -->
      {
        slides.length === 0 ? (
          <div class="text-center py-16">
            <p class="text-neutral-600 dark:text-neutral-400 text-lg">
              No slides available yet.
            </p>
          </div>
        ) : (
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
            {slides.map((slide) => (
              <a
                href={`/slides/${slide.slug}`}
                class={cn(
                  "group relative block",
                  "bg-gradient-to-br from-white/5 to-white/[0.02]",
                  "backdrop-blur-sm",
                  "border border-white/10",
                  "rounded-2xl overflow-hidden",
                  "hover:border-white/20 hover:from-white/[0.07] hover:to-white/[0.03]",
                  "transition-all duration-300",
                  "shadow-lg shadow-black/5 hover:shadow-xl hover:shadow-primary-500/10",
                  "hover:scale-105",
                )}
              >
                {/* Thumbnail */}
                <div class="relative aspect-video bg-gradient-to-br from-primary-500/20 to-accent-500/20 overflow-hidden">
                  {slide.data.thumbnail ? (
                    <img
                      src={slide.data.thumbnail}
                      alt={slide.data.title}
                      class="w-full h-full object-cover"
                    />
                  ) : (
                    <div class="w-full h-full flex items-center justify-center">
                      <svg
                        class="w-16 h-16 text-white/30"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                      >
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          stroke-width="2"
                          d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"
                        />
                      </svg>
                    </div>
                  )}

                  {/* Overlay */}
                  <div class="absolute inset-0 bg-gradient-to-t from-neutral-900/80 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                    <div class="absolute bottom-4 left-4 flex items-center gap-2 text-white text-sm font-medium">
                      <svg
                        class="w-5 h-5"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                      >
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          stroke-width="2"
                          d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"
                        />
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          stroke-width="2"
                          d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
                        />
                      </svg>
                      View Slides
                    </div>
                  </div>
                </div>

                {/* Content */}
                <div class="p-6 space-y-3">
                  <h3 class="text-xl font-bold text-neutral-900 dark:text-white group-hover:text-primary-500 dark:group-hover:text-primary-400 transition-colors">
                    {slide.data.title}
                  </h3>

                  {slide.data.description && (
                    <p class="text-sm text-neutral-600 dark:text-neutral-400 line-clamp-2">
                      {slide.data.description}
                    </p>
                  )}

                  <div class="flex items-center gap-2 text-xs text-neutral-500 dark:text-neutral-500">
                    <svg
                      class="w-4 h-4"
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke="currentColor"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"
                      />
                    </svg>
                    {slide.data.pubDate.toLocaleDateString("en-US", {
                      year: "numeric",
                      month: "long",
                      day: "numeric",
                    })}
                  </div>
                </div>
              </a>
            ))}
          </div>
        )
      }
    </section>
  </div>
</Layout>
