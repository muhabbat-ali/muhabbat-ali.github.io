---
import { getCollection } from "astro:content";
import Button from "../button.astro";
import ServiceCard from "../ServiceCard.astro";

const allProjects = (await getCollection("projects"))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
  <div class="text-center space-y-4 mb-12">
    <h2
      class="text-3xl sm:text-4xl lg:text-5xl font-bold tracking-tight text-neutral-900 dark:text-white"
    >
      Featured <span
        class="bg-gradient-to-r from-primary-600 to-accent-500 bg-clip-text text-transparent"
        >Projects</span
      >
    </h2>
    <p class="text-lg text-neutral-600 dark:text-neutral-400 max-w-2xl mx-auto">
      Here are some of my recent projects. I'm always working on something new,
      so check back often!
    </p>
  </div>

  <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
    {
      allProjects.map((project) => {
        return (
          <ServiceCard
            data={{
              title: project.data.title,
              description: project.data.description,
              thumbnail: project.data.featuredImage,
              link: project.data.link,
              category: project.data.pubDate.toLocaleDateString("en-US", {
                month: "short",
                day: "numeric",
                year: "numeric",
              }),
            }}
            slug={`projects/${project.slug}`}
            id={project.id}
          />
        );
      })
    }
  </div>

  <div class="flex items-center justify-center mt-12">
    <Button text="View All My Projects" link="/projects" />
  </div>
</section>
