---
export interface Props {
  tag: string;
}
const { tag } = Astro.props;
---

<a
  href={`/blog/tags/${encodeURIComponent(tag.toLowerCase())}`}
  aria-label={tag}
  class="inline-block"
>
  <span
    class="inline-flex items-center gap-1 px-4 py-2 rounded-xl text-xs font-semibold bg-primary-100 dark:bg-primary-900/30 text-primary-700 dark:text-primary-300 border border-primary-200 dark:border-primary-800 hover:bg-primary-200 dark:hover:bg-primary-800/50 hover:scale-105 transition-all duration-300"
  >
    <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        d="M7 20l4-16m2 16l4-16M6 9h14M4 15h14"></path>
    </svg>
    {tag ?? "Blog Tag"}
  </span>
</a>
