---
import HeaderLink from "@/components/HeaderLink";
import TwitterIcon from "@/components/icons/TwitterIcon";
import GithubIcon from "@/components/icons/GithubIcon";
import MenuIcon from "./icons/MenuIcon.astro";
import Search from "@/components/Search";
import TagIcon from "./icons/TagIcon.astro";
import ToggleTheme from "./ToggleTheme.astro";
import Logo from "../components/logo.astro";
import InstagramIcon from "./icons/Instagram.astro";
import PortfolioIcon from "./icons/Portfolio.astro";

// ADD YOUR SOCIAL NETWORKS HERE
const SOCIALNETWORKS = [
  {
    name: "Github",
    url: "https://github.com/muhabbat-dev",
    icon: GithubIcon,
  },
  // {
  // 	name: 'Instagram',
  // 	url: 'https://instagram.com/codingbuddy',
  // 	icon: InstagramIcon
  // },
  // {
  // 	name: 'Portfolio',
  // 	url: 'https://me.coding-buddy.com',
  // 	icon: TwitterIcon
  // },
  {
    name: "Twitter",
    url: "https://twiter.com/MuhabbatDev",
    icon: TwitterIcon,
  },
];
---

<header
  class="sticky top-0 z-50 backdrop-blur-xl bg-white/80 dark:bg-neutral-950/80 border-b border-neutral-200 dark:border-neutral-800 transition-all duration-300"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <Logo />

      <div
        id="astro-header-drawer"
        class="bg-white dark:bg-neutral-950 absolute transition-all duration-300 ease-in-out translate-x-full top-16 right-0 w-64 h-screen shadow-2xl border-l border-neutral-200 dark:border-neutral-800 z-50 md:bg-transparent md:dark:bg-transparent md:shadow-none md:rounded-none md:border-none md:h-auto md:static md:translate-x-0 md:w-auto"
      >
        <nav
          class="flex h-full flex-col md:flex-row justify-start md:justify-between gap-8 md:gap-6 p-6 md:p-0"
        >
          <div class="flex flex-col md:flex-row gap-6 md:gap-4 md:items-center">
            <HeaderLink
              href="/blog/tags"
              class="flex items-center gap-2 text-base font-medium text-neutral-700 dark:text-neutral-300 hover:text-primary-600 dark:hover:text-primary-400 transition-colors"
            >
              <TagIcon /> Tags
            </HeaderLink>
          </div>

          <div class="flex flex-col md:flex-row gap-4 md:gap-3 md:items-center">
            {
              SOCIALNETWORKS.map((network) => (
                <HeaderLink
                  class="flex items-center gap-2 text-neutral-700 dark:text-neutral-300 hover:text-primary-600 dark:hover:text-primary-400 transition-colors"
                  href={network.url}
                  target="_blank"
                  aria-label={network.name}
                >
                  <span class="w-5 h-5">{<network.icon />}</span>
                  <span class="md:hidden">{network.name}</span>
                </HeaderLink>
              ))
            }
          </div>
        </nav>
      </div>

      <div class="flex items-center gap-3" transition:persist="navbar">
        <div>
          <Search />
        </div>
        <ToggleTheme />
        <button
          id="astro-header-drawer-button"
          type="button"
          class="md:hidden p-2 rounded-lg hover:bg-neutral-100 dark:hover:bg-neutral-900 transition-colors"
          aria-label="Toggle menu"
        >
          <MenuIcon />
        </button>
      </div>
    </div>
  </div>
</header>

<script>
  const menu = document.getElementById("astro-header-drawer");
  const menuButton = document.getElementById("astro-header-drawer-button");

  menuButton?.addEventListener("click", () => {
    menu?.classList.toggle("translate-x-full");
  });

  // Close menu when clicking outside
  document.addEventListener("click", (event) => {
    const isClickInside =
      menu?.contains(event.target as Node) ||
      menuButton?.contains(event.target as Node);

    if (
      !isClickInside &&
      menu &&
      !menu.classList.contains("translate-x-full")
    ) {
      menu.classList.add("translate-x-full");
    }
  });

  // Close menu when pressing Escape
  document.addEventListener("keydown", (event) => {
    if (
      event.key === "Escape" &&
      menu &&
      !menu.classList.contains("translate-x-full")
    ) {
      menu.classList.add("translate-x-full");
    }
  });
</script>
