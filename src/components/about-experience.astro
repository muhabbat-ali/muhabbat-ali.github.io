---
const { logo, startDate, endDate, current, role, company, children } =
  Astro.props;

const dateRange = current
  ? `${startDate} · Present`
  : `${startDate} · ${endDate}`;
---

<div class="relative group">
  <!-- Timeline Dot (Desktop only) -->
  <div class="hidden md:block absolute -left-8 top-2">
    <div
      class="w-4 h-4 rounded-full bg-gradient-to-r from-primary-600 to-accent-500 ring-4 ring-white dark:ring-neutral-950 group-hover:scale-125 transition-transform duration-300"
    >
    </div>
  </div>

  <!-- Content Card -->
  <div
    class="glass rounded-2xl p-4 sm:p-6 hover:shadow-lg transition-all duration-300"
  >
    <!-- Mobile Timeline Indicator & Logo -->
    <div class="flex items-center gap-3 mb-4 md:hidden">
      <div
        class="w-3 h-3 rounded-full bg-gradient-to-r from-primary-600 to-accent-500 flex-shrink-0"
      >
      </div>
      <div
        class="w-12 h-12 rounded-xl bg-white dark:bg-neutral-800 border border-neutral-200 dark:border-neutral-700 flex items-center justify-center overflow-hidden flex-shrink-0"
      >
        <img src={logo} alt={company} class="w-8 h-8 object-contain" />
      </div>
    </div>

    <div class="flex flex-col md:flex-row md:items-start gap-4">
      <!-- Logo (Desktop) -->
      <div
        class="hidden md:flex flex-shrink-0 w-12 h-12 rounded-xl bg-white dark:bg-neutral-800 border border-neutral-200 dark:border-neutral-700 items-center justify-center overflow-hidden group-hover:scale-110 transition-transform duration-300"
      >
        <img src={logo} alt={company} class="w-8 h-8 object-contain" />
      </div>

      <!-- Details -->
      <div class="flex-1 space-y-2">
        <p
          class="text-xs font-semibold uppercase tracking-wider text-primary-600 dark:text-primary-400"
        >
          {dateRange}
        </p>
        <h3
          class="text-lg sm:text-xl font-bold text-neutral-900 dark:text-white"
        >
          {role}
        </h3>
        <p
          class="text-sm sm:text-base font-medium text-neutral-700 dark:text-neutral-300"
        >
          {company}
        </p>
        <div
          class="text-sm sm:text-base text-neutral-600 dark:text-neutral-400 leading-relaxed pt-1 prose prose-sm sm:prose-base dark:prose-invert max-w-none
          prose-p:my-2 prose-p:leading-relaxed
          prose-ul:my-2 prose-ul:list-disc prose-ul:pl-5
          prose-li:my-1 prose-li:text-neutral-600 dark:prose-li:text-neutral-400
          prose-strong:text-neutral-900 dark:prose-strong:text-white prose-strong:font-semibold"
        >
          <slot />
        </div>
      </div>
    </div>
  </div>
</div>
