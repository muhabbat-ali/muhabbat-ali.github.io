---
import { cn } from "@/utils";

interface Props {
  degree: string;
  field?: string;
  institution: string;
  logo?: string;
  startDate: string;
  endDate?: string;
  current?: boolean;
  location: string;
}

const {
  degree,
  field,
  institution,
  logo,
  startDate,
  endDate,
  current,
  location,
} = Astro.props;

const period = current
  ? `${startDate} - Present`
  : endDate
    ? `${startDate} - ${endDate}`
    : startDate;
---

<div
  class={cn(
    "relative group",
    "bg-gradient-to-br from-white/5 to-white/[0.02]",
    "backdrop-blur-sm",
    "border border-white/10",
    "rounded-2xl p-6 lg:p-8",
    "hover:border-white/20 hover:from-white/[0.07] hover:to-white/[0.03]",
    "transition-all duration-300",
    "shadow-lg shadow-black/5 hover:shadow-xl hover:shadow-primary-500/10",
  )}
>
  <div class="flex flex-col md:flex-row gap-6">
    {
      logo && (
        <div class="flex-shrink-0">
          <div
            class={cn(
              "w-16 h-16 md:w-20 md:h-20",
              "rounded-xl",
              "bg-gradient-to-br from-white/10 to-white/5",
              "border border-white/10",
              "flex items-center justify-center",
              "overflow-hidden",
              "group-hover:scale-105 transition-transform duration-300",
            )}
          >
            <img
              src={logo}
              alt={institution}
              class="w-full h-full object-contain p-2"
            />
          </div>
        </div>
      )
    }

    <div class="flex-1 space-y-3">
      <div>
        <h3
          class={cn(
            "text-xl md:text-2xl font-bold",
            "bg-gradient-to-r from-blue-400 via-purple-400 to-pink-400",
            "bg-clip-text text-transparent",
            "mb-1",
          )}
        >
          {degree}
        </h3>
        {
          field && (
            <p class="text-base md:text-lg text-gray-300 font-medium">
              {field}
            </p>
          )
        }
      </div>

      <div class="flex flex-wrap gap-4 text-sm md:text-base text-gray-400">
        <div class="flex items-center gap-2">
          <span class="text-lg">🏛️</span>
          <span class="font-medium">{institution}</span>
        </div>
        <div class="flex items-center gap-2">
          <span class="text-lg">📅</span>
          <span>{period}</span>
        </div>
        <div class="flex items-center gap-2">
          <span class="text-lg">📍</span>
          <span>{location}</span>
        </div>
      </div>

      {
        current && (
          <div
            class={cn(
              "inline-flex items-center gap-2 px-3 py-1",
              "bg-gradient-to-r from-green-500/20 to-emerald-500/20",
              "border border-green-500/30",
              "rounded-full text-sm text-green-400 font-medium",
            )}
          >
            <span class="w-2 h-2 bg-green-400 rounded-full animate-pulse" />
            Currently Enrolled
          </div>
        )
      }

      <div
        class={cn(
          "prose prose-invert prose-sm md:prose-base max-w-none",
          "prose-headings:text-gray-200 prose-headings:font-semibold",
          "prose-p:text-gray-300 prose-p:leading-relaxed",
          "prose-strong:text-blue-400 prose-strong:font-semibold",
          "prose-ul:text-gray-300",
          "prose-li:marker:text-purple-400",
        )}
      >
        <slot />
      </div>
    </div>
  </div>
</div>
