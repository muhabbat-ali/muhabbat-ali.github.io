---
import Title from "./Title.astro";
// import Shape from './icons/Shape.astro'
type Props = {
  title: string;
};

const { title } = Astro.props;
---

<div class="flex justify-center items-center gap-3 mb-8 title">
  <div
    class="w-1 h-12 bg-gradient-to-b from-primary-500 to-accent-500 rounded-full"
  >
  </div>
  <Title>{title}</Title>
  <div
    class="w-1 h-12 bg-gradient-to-b from-accent-500 to-primary-500 rounded-full"
  >
  </div>
</div>
