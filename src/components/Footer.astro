---
import Logo from "../components/logo.astro";
---

<footer
  class="relative overflow-hidden bg-white dark:bg-neutral-950 border-t border-neutral-200 dark:border-neutral-800 mt-20"
>
  <!-- Background Decoration -->
  <div class="absolute inset-0 -z-10">
    <div
      class="absolute bottom-0 left-0 w-96 h-96 bg-primary-500/5 rounded-full blur-3xl"
    >
    </div>
    <div
      class="absolute top-0 right-0 w-96 h-96 bg-accent-500/5 rounded-full blur-3xl"
    >
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-12">
      <!-- Logo & Copyright -->
      <div class="space-y-4">
        <Logo />
        <p class="text-sm text-neutral-600 dark:text-neutral-400">
          Full Stack Developer & DevOps Engineer
        </p>
        <p class="text-xs text-neutral-500 dark:text-neutral-500">
          © {new Date().getFullYear()} Muhabbat Ali. All rights reserved.
        </p>
      </div>

      <!-- Quick Links -->
      <div class="space-y-4">
        <h3
          class="text-sm font-bold text-neutral-900 dark:text-white uppercase tracking-wider"
        >
          Quick Links
        </h3>
        <nav class="flex flex-col space-y-2">
          <a
            href="/"
            class="text-sm text-neutral-600 dark:text-neutral-400 hover:text-primary-600 dark:hover:text-primary-400 transition-colors"
          >
            Home
          </a>
          <a
            href="/about"
            class="text-sm text-neutral-600 dark:text-neutral-400 hover:text-primary-600 dark:hover:text-primary-400 transition-colors"
          >
            About
          </a>
          <a
            href="/projects"
            class="text-sm text-neutral-600 dark:text-neutral-400 hover:text-primary-600 dark:hover:text-primary-400 transition-colors"
          >
            Projects
          </a>
          <a
            href="/privacy"
            class="text-sm text-neutral-600 dark:text-neutral-400 hover:text-primary-600 dark:hover:text-primary-400 transition-colors"
          >
            Privacy Policy
          </a>
          <a
            href="/terms-and-conditions"
            class="text-sm text-neutral-600 dark:text-neutral-400 hover:text-primary-600 dark:hover:text-primary-400 transition-colors"
          >
            Terms & Conditions
          </a>
        </nav>
      </div>

      <!-- Social Links -->
      <div class="space-y-4">
        <h3
          class="text-sm font-bold text-neutral-900 dark:text-white uppercase tracking-wider"
        >
          Connect
        </h3>
        <div class="flex flex-wrap gap-3">
          <a
            href="https://www.linkedin.com/in/muhabbat-ali/"
            target="_blank"
            rel="noopener noreferrer"
            class="group flex items-center justify-center w-10 h-10 rounded-xl bg-neutral-100 dark:bg-neutral-900 hover:bg-gradient-to-r hover:from-primary-600 hover:to-accent-500 transition-all duration-300"
            aria-label="LinkedIn"
          >
            <svg
              class="w-5 h-5 text-neutral-700 dark:text-neutral-300 group-hover:text-white transition-colors"
              viewBox="0 0 24 24"
              fill="currentColor"
              xmlns="http://www.w3.org/2000/svg"
            >
              <path
                d="M6.5 8C7.32843 8 8 7.32843 8 6.5C8 5.67157 7.32843 5 6.5 5C5.67157 5 5 5.67157 5 6.5C5 7.32843 5.67157 8 6.5 8Z"
              ></path>
              <path
                d="M5 10C5 9.44772 5.44772 9 6 9H7C7.55228 9 8 9.44771 8 10V18C8 18.5523 7.55228 19 7 19H6C5.44772 19 5 18.5523 5 18V10Z"
              ></path>
              <path
                d="M11 19H12C12.5523 19 13 18.5523 13 18V13.5C13 12 16 11 16 13V18.0004C16 18.5527 16.4477 19 17 19H18C18.5523 19 19 18.5523 19 18V12C19 10 17.5 9 15.5 9C13.5 9 13 10.5 13 10.5V10C13 9.44771 12.5523 9 12 9H11C10.4477 9 10 9.44772 10 10V18C10 18.5523 10.4477 19 11 19Z"
              ></path>
            </svg>
          </a>

          <a
            href="https://twitter.com/MuhabbatDev"
            target="_blank"
            rel="noopener noreferrer"
            class="group flex items-center justify-center w-10 h-10 rounded-xl bg-neutral-100 dark:bg-neutral-900 hover:bg-gradient-to-r hover:from-primary-600 hover:to-accent-500 transition-all duration-300"
            aria-label="Twitter/X"
          >
            <svg
              class="w-5 h-5 text-neutral-700 dark:text-neutral-300 group-hover:text-white transition-colors"
              viewBox="0 0 24 24"
              fill="currentColor"
            >
              <path
                d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"
              ></path>
            </svg>
          </a>

          <a
            href="https://github.com/muhabbat-dev"
            target="_blank"
            rel="noopener noreferrer"
            class="group flex items-center justify-center w-10 h-10 rounded-xl bg-neutral-100 dark:bg-neutral-900 hover:bg-gradient-to-r hover:from-primary-600 hover:to-accent-500 transition-all duration-300"
            aria-label="GitHub"
          >
            <svg
              class="w-5 h-5 text-neutral-700 dark:text-neutral-300 group-hover:text-white transition-colors"
              fill="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                fill-rule="evenodd"
                d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"
                clip-rule="evenodd"></path>
            </svg>
          </a>
        </div>
      </div>
    </div>

    <!-- Divider -->
    <div class="mt-8 pt-8 border-t border-neutral-200 dark:border-neutral-800">
      <p class="text-center text-sm text-neutral-500 dark:text-neutral-500">
        Made with <span class="text-red-500">❤️</span> using Astro & Tailwind CSS
      </p>
    </div>
  </div>
</footer>
